# family-reminder-cloud — local environment template
# Copy this file to `.env` and fill in real values. `.env` is gitignored
# (never commit it). See .gitleaks.toml + security-scan.yml for context.

# ── Web Push (VAPID) ──
# Generate a keypair once with:  npx web-push generate-vapid-keys
# Put the PUBLIC key here AND in index.html / home.html (client-side required),
# and the PRIVATE key ONLY here (server-side, never committed).
VAPID_PUBLIC_KEY=BMXfjmwf83dWRooUSAD1W2HmS-vyGVmVGOYFEfzJNziK4w2OXYtqBU1AyhdSMF0JL1jds03sGF7OXSmL9VL1-2I
# VAPID_PRIVATE_KEY is intentionally NOT stored here (this file is committed to
# the public repo). Put the real private key in your local .env (gitignored).
# A keypair was ROTATED on 2026-07-19 because the previous private key was
# committed to public git history and therefore compromised.
# To regenerate a fresh pair:  npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=<your-vapid-private-key-here>

# ── GitHub token ── fine-grained or classic PAT with `repo` scope (data sync / API writes)
GH_PAT=

# ── CallMeBot WhatsApp API keys (one per caregiver) ──
CALLMEBOT_KEN=
CALLMEBOT_EPPIE=
CALLMEBOT_KENNY=
CALLMEBOT_ROSANNA=
CALLMEBOT_COFFE=
CALLMEBOT_LODOU=
